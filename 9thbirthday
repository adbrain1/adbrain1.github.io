<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>Abdul Rafay's 9th Birthday!</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lilita+One&family=Baloo+2:wght@500;600;700;800&display=swap" rel="stylesheet">
<style>
  /* ============ SETTINGS YOU CAN CHANGE ============ */
  :root{
    --name: "Abdul Rafay";
    --sky-top:#0e3b4a;
    --sky-mid:#1f7a6b;
    --sky-low:#f6c66b;
    --leaf-1:#0b2e1d;
    --leaf-2:#13452b;
    --leaf-3:#1c6b3f;
    --leaf-4:#2a8f54;
    --cream:#fff7e6;
    --gold:#ffcf4d;
    --accent:#ff6b6b;
    --accent2:#36c6a8;
  }

  /* ============ BASIC RESET / NO SCROLLBAR ============ */
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  html,body{height:100%;width:100%;overflow:hidden;background:#06121a;}
  body{
    font-family:"Baloo 2",system-ui,sans-serif;
    position:fixed;inset:0;
    -webkit-user-select:none;user-select:none;
  }
  #app{
    position:relative;
    height:100dvh;width:100vw;
    overflow:hidden;
  }

  /* ============ SKY BACKGROUND ============ */
  .sky{
    position:absolute;inset:0;
    background:linear-gradient(to bottom,var(--sky-top) 0%,var(--sky-mid) 48%,var(--sky-low) 100%);
    transition:opacity 1.4s ease;
  }
  .sun-glow{
    position:absolute;left:50%;bottom:18%;
    width:80vmin;height:80vmin;transform:translateX(-50%);
    background:radial-gradient(circle,rgba(255,236,170,.55) 0%,rgba(255,236,170,0) 60%);
    opacity:0;transition:opacity 2s ease 0.6s;
    pointer-events:none;
  }

  /* ============ RAINBOW ============ */
  .rainbow{
    position:absolute;left:50%;top:50%;
    transform:translate(-50%,-50%) scale(.2);
    width:135vmin;max-width:1100px;
    opacity:0;
    transition:opacity 1.1s ease, transform 1.4s cubic-bezier(.2,.9,.3,1);
    pointer-events:none;
    filter:drop-shadow(0 8px 24px rgba(0,0,0,.18));
  }
  .rainbow.show{opacity:.95;transform:translate(-50%,-58%) scale(1);}
  .band{
    fill:none;stroke-width:11;stroke-linecap:round;
    stroke-dasharray:1300;stroke-dashoffset:1300;
  }
  .rainbow.show .band{animation:draw 1.4s ease forwards;}
  @keyframes draw{to{stroke-dashoffset:0;}}

  /* ============ JUNGLE LAYERS ============ */
  .jungle{position:absolute;inset:0;pointer-events:none;}
  .layer{
    position:absolute;left:0;bottom:0;width:100%;
    opacity:0;transform:translateY(40px);
    transition:opacity 1.2s ease, transform 1.4s cubic-bezier(.2,.9,.3,1);
  }
  .reveal .layer{opacity:1;transform:translateY(0);}
  .reveal .sun-glow{opacity:1;}
  .l1{height:46%;z-index:2;transition-delay:.15s;}
  .l2{height:34%;z-index:3;transition-delay:.30s;}
  .l3{height:24%;z-index:4;transition-delay:.45s;}
  .layer svg{position:absolute;bottom:0;width:100%;height:100%;}

  /* gentle sway */
  .frond{transform-origin:bottom center;animation:sway 6s ease-in-out infinite;}
  .frond.b{animation-duration:7.5s;animation-delay:-2s;}
  @keyframes sway{0%,100%{transform:rotate(-1.5deg);}50%{transform:rotate(1.5deg);}}

  /* ============ FIREFLIES & BUTTERFLIES ============ */
  .critters{position:absolute;inset:0;z-index:5;pointer-events:none;opacity:0;transition:opacity 1.5s ease 0.8s;}
  .reveal .critters{opacity:1;}
  .fly{position:absolute;width:7px;height:7px;border-radius:50%;
    background:radial-gradient(circle,#fff7b0,#ffd34d);
    box-shadow:0 0 10px 3px rgba(255,221,87,.8);
    animation:float 9s ease-in-out infinite;}
  @keyframes float{
    0%{transform:translate(0,0);opacity:.3;}
    25%{opacity:1;}
    50%{transform:translate(28px,-34px);opacity:.7;}
    75%{opacity:1;}
    100%{transform:translate(-14px,12px);opacity:.3;}
  }
  .butterfly{position:absolute;font-size:26px;animation:bfly 14s linear infinite;filter:drop-shadow(0 3px 4px rgba(0,0,0,.25));}
  @keyframes bfly{
    0%{transform:translate(-10vw,20vh) rotate(8deg);}
    50%{transform:translate(55vw,-8vh) rotate(-8deg);}
    100%{transform:translate(110vw,18vh) rotate(8deg);}
  }

  /* ============ FIREWORK CANVAS ============ */
  #fw{position:absolute;inset:0;z-index:30;pointer-events:none;}

  /* ============ START SCREEN ============ */
  #startScreen{
    position:absolute;inset:0;z-index:60;
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    gap:26px;text-align:center;padding:24px;
    background:radial-gradient(circle at 50% 40%,#10303a,#06121a);
    transition:opacity .7s ease;
  }
  #startScreen h2{
    font-family:"Lilita One";color:var(--cream);
    font-size:clamp(22px,6vw,40px);line-height:1.1;
    text-shadow:0 3px 0 rgba(0,0,0,.25);
  }
  .startBtn{
    font-family:"Lilita One";font-size:clamp(20px,5vw,30px);
    color:#3a2200;background:linear-gradient(180deg,#ffe08a,var(--gold));
    border:none;border-radius:999px;padding:18px 42px;cursor:pointer;
    box-shadow:0 8px 0 #c9941f,0 14px 24px rgba(0,0,0,.35);
    transition:transform .12s ease;
    animation:pulse 1.8s ease-in-out infinite;
  }
  .startBtn:active{transform:translateY(5px);box-shadow:0 3px 0 #c9941f,0 6px 12px rgba(0,0,0,.35);}
  @keyframes pulse{0%,100%{transform:scale(1);}50%{transform:scale(1.06);}}
  .muteNote{color:#bfe6dd;font-size:13px;opacity:.85;}

  /* ============ CONTENT PANELS (welcome + questions) ============ */
  #ui{position:absolute;inset:0;z-index:40;display:flex;align-items:center;justify-content:center;padding:20px;}
  .panel{
    position:absolute;width:min(90vw,560px);
    display:none;flex-direction:column;align-items:center;text-align:center;gap:18px;
    opacity:0;transform:translateY(22px) scale(.98);
    transition:opacity .55s ease, transform .55s cubic-bezier(.2,.9,.3,1);
  }
  .panel.active{display:flex;opacity:1;transform:translateY(0) scale(1);}

  .card{
    background:rgba(255,247,230,.92);
    border:3px solid #fff;
    border-radius:28px;
    padding:clamp(18px,5vw,34px);
    box-shadow:0 18px 50px rgba(0,0,0,.4), inset 0 0 0 6px rgba(255,207,77,.35);
    backdrop-filter:blur(3px);
    width:100%;
  }
  .title{
    font-family:"Lilita One";color:#1c6b3f;
    font-size:clamp(26px,7vw,48px);line-height:1.05;
    text-shadow:0 2px 0 rgba(255,255,255,.6);
  }
  .title .hi{color:var(--accent);display:block;}
  .sub{font-size:clamp(15px,4vw,20px);color:#5a4a2a;font-weight:600;margin-top:8px;}
  .date{
    display:inline-block;margin-top:14px;font-family:"Lilita One";
    background:var(--accent);color:#fff;padding:8px 20px;border-radius:999px;
    font-size:clamp(15px,4.2vw,22px);box-shadow:0 6px 0 #d94f4f;
  }
  .q{font-family:"Lilita One";color:#1c6b3f;font-size:clamp(20px,5.5vw,30px);line-height:1.15;}

  .btnRow{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;margin-top:6px;}
  .choice{
    font-family:"Baloo 2";font-weight:800;font-size:clamp(16px,4.5vw,22px);
    color:#fff;border:none;border-radius:18px;padding:16px 30px;cursor:pointer;
    transition:transform .12s ease, filter .12s ease;min-width:120px;
  }
  .choice:active{transform:translateY(4px);}
  .yes{background:linear-gradient(180deg,#46d39a,#23a378);box-shadow:0 6px 0 #1a7d5c;}
  .no{background:linear-gradient(180deg,#ff8a8a,#ef5b5b);box-shadow:0 6px 0 #c33;}
  .opt{background:linear-gradient(180deg,#7fb3ff,#4f86e6);box-shadow:0 6px 0 #3a63b0;}
  .choice.sel{filter:brightness(1.12);outline:4px solid var(--gold);}

  .field{
    width:100%;font-family:"Baloo 2";font-weight:600;font-size:clamp(16px,4.5vw,20px);
    padding:16px 18px;border:3px solid #e7d8b5;border-radius:16px;background:#fffdf7;color:#3a2f15;
    text-align:center;outline:none;margin-top:6px;
  }
  .field:focus{border-color:var(--gold);box-shadow:0 0 0 4px rgba(255,207,77,.3);}

  .next{
    font-family:"Lilita One";font-size:clamp(18px,4.8vw,24px);color:#3a2200;
    background:linear-gradient(180deg,#ffe08a,var(--gold));border:none;border-radius:999px;
    padding:14px 38px;cursor:pointer;box-shadow:0 7px 0 #c9941f;margin-top:8px;transition:transform .12s ease;
  }
  .next:active{transform:translateY(4px);box-shadow:0 3px 0 #c9941f;}
  .next:disabled{opacity:.45;cursor:not-allowed;box-shadow:0 7px 0 #c9941f;}

  .progress{display:flex;gap:8px;justify-content:center;margin-top:4px;}
  .dot{width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,.45);transition:.3s;}
  .dot.on{background:var(--gold);transform:scale(1.25);}

  .small{font-size:13px;color:#7a6a45;margin-top:4px;}
  .confetti{position:absolute;inset:0;z-index:45;pointer-events:none;}
</style>
</head>
<body>
<div id="app">

  <!-- Sky + scene -->
  <div class="sky" id="sky"></div>
  <div class="sun-glow"></div>

  <!-- Rainbow -->
  <svg class="rainbow" id="rainbow" viewBox="0 0 400 220" aria-hidden="true">
    <path class="band" style="stroke:#ff5a5a" d="M30 220 A170 170 0 0 1 370 220"/>
    <path class="band" style="stroke:#ff9f43" d="M44 220 A156 156 0 0 1 356 220"/>
    <path class="band" style="stroke:#ffd93d" d="M58 220 A142 142 0 0 1 342 220"/>
    <path class="band" style="stroke:#4cd97b" d="M72 220 A128 128 0 0 1 328 220"/>
    <path class="band" style="stroke:#4db8ff" d="M86 220 A114 114 0 0 1 314 220"/>
    <path class="band" style="stroke:#5a6bff" d="M100 220 A100 100 0 0 1 300 220"/>
    <path class="band" style="stroke:#b56bff" d="M114 220 A86 86 0 0 1 286 220"/>
  </svg>

  <!-- Jungle -->
  <div class="jungle" id="jungle">
    <!-- back layer -->
    <div class="layer l1">
      <svg viewBox="0 0 1200 300" preserveAspectRatio="none">
        <path fill="var(--leaf-3)" d="M0 300 V120 Q150 40 300 110 T600 90 T900 120 T1200 80 V300 Z"/>
      </svg>
    </div>
    <!-- mid layer -->
    <div class="layer l2">
      <svg viewBox="0 0 1200 260" preserveAspectRatio="none">
        <path fill="var(--leaf-2)" d="M0 260 V90 Q200 20 400 80 T800 70 T1200 60 V260 Z"/>
      </svg>
    </div>
    <!-- front leaves -->
    <div class="layer l3">
      <svg viewBox="0 0 1200 200" preserveAspectRatio="none">
        <path fill="var(--leaf-1)" d="M0 200 V70 Q150 10 320 70 Q480 120 640 60 Q820 0 1000 70 Q1100 110 1200 60 V200 Z"/>
        <g class="frond" fill="var(--leaf-1)">
          <path d="M120 200 q-40 -120 10 -180 q30 70 30 180 Z"/>
        </g>
        <g class="frond b" fill="var(--leaf-1)">
          <path d="M1080 200 q40 -120 -10 -180 q-30 70 -30 180 Z"/>
        </g>
      </svg>
    </div>
  </div>

  <!-- fireflies + butterflies -->
  <div class="critters" id="critters"></div>

  <!-- firework canvas -->
  <canvas id="fw"></canvas>

  <!-- confetti for thank you -->
  <canvas class="confetti" id="confetti"></canvas>

  <!-- UI panels -->
  <div id="ui">

    <!-- Welcome -->
    <div class="panel" id="p-welcome">
      <div class="card">
        <div class="title"><span class="hi">Come celebrate</span>Abdul Rafay's 9th Birthday!</div>
        <div class="sub">Join us in the heart of the rainforest 🌿</div>
        <div class="date">📅 Saturday, June 28</div>
      </div>
      <button class="next" onclick="goto('q1')">Let's RSVP! →</button>
    </div>

    <!-- Q1 -->
    <div class="panel" id="p-q1">
      <div class="card">
        <div class="q">Is your child celebrating with us? 🎉</div>
        <div class="btnRow">
          <button class="choice yes" onclick="answerAttend(true)">Yes 🙌</button>
          <button class="choice no" onclick="answerAttend(false)">No 😔</button>
        </div>
      </div>
      <div class="progress"><span class="dot on"></span><span class="dot"></span><span class="dot"></span></div>
    </div>

    <!-- Q2 name -->
    <div class="panel" id="p-q2">
      <div class="card">
        <div class="q">Wonderful! What is your child's name? 😊</div>
        <input class="field" id="childName" type="text" placeholder="Type the name here" autocomplete="off" oninput="checkName()">
      </div>
      <button class="next" id="nameNext" disabled onclick="goto('q3')">Next →</button>
      <div class="progress"><span class="dot on"></span><span class="dot on"></span><span class="dot"></span></div>
    </div>

    <!-- Q3 contact method -->
    <div class="panel" id="p-q3">
      <div class="card">
        <div class="q">Best way to reach you? 📨</div>
        <div class="btnRow">
          <button class="choice opt" id="m-email" onclick="answerMethod('Email')">✉️ Email</button>
          <button class="choice opt" id="m-phone" onclick="answerMethod('Phone')">📞 Phone</button>
        </div>
      </div>
      <div class="progress"><span class="dot on"></span><span class="dot on"></span><span class="dot on"></span></div>
    </div>

    <!-- Q4 contact detail -->
    <div class="panel" id="p-q4">
      <div class="card">
        <div class="q" id="q4label">Please enter your details 📝</div>
        <input class="field" id="contactDetail" type="text" placeholder="" autocomplete="off" oninput="checkContact()">
      </div>
      <button class="next" id="sendBtn" disabled onclick="submitForm()">Send RSVP 🎈</button>
      <div class="progress"><span class="dot on"></span><span class="dot on"></span><span class="dot on"></span></div>
    </div>

    <!-- Thank you (attending) -->
    <div class="panel" id="p-thanks">
      <div class="card">
        <div class="title" style="color:var(--accent)">Yay! 🎉</div>
        <div class="sub" id="thanksMsg">Thank you! We can't wait to see you at the party!</div>
        <div class="date">📅 Saturday, June 28</div>
      </div>
    </div>

    <!-- Goodbye (not attending) -->
    <div class="panel" id="p-bye">
      <div class="card">
        <div class="title" style="color:#1c6b3f">Aww 💚</div>
        <div class="sub">We'll miss you! Thank you for letting us know.</div>
      </div>
    </div>

  </div>

  <!-- START SCREEN -->
  <div id="startScreen">
    <h2>You're invited to<br>Abdul Rafay's 9th Birthday! 🎆</h2>
    <button class="startBtn" id="startBtn">🔊 Tap to Begin</button>
    <div class="muteNote">Turn your sound on for the full surprise!</div>
  </div>

</div>

<script>
/* ====================================================
   1) FIREFLIES & BUTTERFLIES (built once)
==================================================== */
(function(){
  const c=document.getElementById('critters');
  for(let i=0;i<14;i++){
    const f=document.createElement('div');f.className='fly';
    f.style.left=(Math.random()*100)+'%';
    f.style.top=(40+Math.random()*55)+'%';
    f.style.animationDelay=(-Math.random()*9)+'s';
    f.style.animationDuration=(7+Math.random()*6)+'s';
    c.appendChild(f);
  }
  ['🦋','🦜','🦋'].forEach((e,i)=>{
    const b=document.createElement('div');b.className='butterfly';b.textContent=e;
    b.style.animationDelay=(-i*5)+'s';
    b.style.animationDuration=(13+i*3)+'s';
    c.appendChild(b);
  });
})();

/* ====================================================
   2) SOUND (no files needed - made by the browser)
==================================================== */
let AC=null;
function makeAudio(){ if(!AC){ AC=new (window.AudioContext||window.webkitAudioContext)(); } }
function whistle(){
  const t=AC.currentTime, o=AC.createOscillator(), g=AC.createGain();
  o.type='triangle';
  o.frequency.setValueAtTime(900,t);
  o.frequency.exponentialRampToValueAtTime(1900,t+0.9);
  g.gain.setValueAtTime(0.0001,t);
  g.gain.exponentialRampToValueAtTime(0.12,t+0.1);
  g.gain.exponentialRampToValueAtTime(0.0001,t+0.95);
  o.connect(g).connect(AC.destination); o.start(t); o.stop(t+1);
}
function boom(){
  const t=AC.currentTime, dur=1.0;
  const buf=AC.createBuffer(1,AC.sampleRate*dur,AC.sampleRate);
  const d=buf.getChannelData(0);
  for(let i=0;i<d.length;i++){ d[i]=(Math.random()*2-1)*Math.pow(1-i/d.length,2); }
  const src=AC.createBufferSource(); src.buffer=buf;
  const lp=AC.createBiquadFilter(); lp.type='lowpass'; lp.frequency.value=900;
  const g=AC.createGain();
  g.gain.setValueAtTime(0.9,t);
  g.gain.exponentialRampToValueAtTime(0.0001,t+dur);
  src.connect(lp).connect(g).connect(AC.destination); src.start(t);
  // little crackles
  for(let k=0;k<6;k++){
    const ot=t+0.15+Math.random()*0.5, oo=AC.createOscillator(), og=AC.createGain();
    oo.type='square'; oo.frequency.value=200+Math.random()*1200;
    og.gain.setValueAtTime(0.08,ot); og.gain.exponentialRampToValueAtTime(0.0001,ot+0.12);
    oo.connect(og).connect(AC.destination); oo.start(ot); oo.stop(ot+0.13);
  }
}

/* ====================================================
   3) FIREWORK ANIMATION (canvas)
==================================================== */
const cv=document.getElementById('fw'), cx=cv.getContext('2d');
function size(){cv.width=innerWidth;cv.height=innerHeight;}
size(); addEventListener('resize',size);
let parts=[], rocket=null, running=false;
const COLORS=['#ff5a5a','#ffd93d','#4cd97b','#4db8ff','#b56bff','#ff9f43'];

function launch(){
  running=true;
  rocket={x:innerWidth/2,y:innerHeight,vy:-(innerHeight*0.018),tx:innerHeight*0.34,trail:[]};
  requestAnimationFrame(loop);
}
function explode(x,y){
  for(let i=0;i<150;i++){
    const a=Math.random()*Math.PI*2, s=Math.random()*7+1.5;
    parts.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,
      life:1,col:COLORS[(Math.random()*COLORS.length)|0],r:Math.random()*2+1.5});
  }
}
function loop(){
  cx.clearRect(0,0,cv.width,cv.height);
  if(rocket){
    rocket.trail.push({x:rocket.x,y:rocket.y});
    if(rocket.trail.length>10)rocket.trail.shift();
    rocket.trail.forEach((p,i)=>{cx.globalAlpha=i/10;cx.fillStyle='#ffe08a';
      cx.beginPath();cx.arc(p.x,p.y,2.5,0,7);cx.fill();});
    cx.globalAlpha=1;
    rocket.y+=rocket.vy;
    if(rocket.y<=rocket.tx){ explode(rocket.x,rocket.y); rocket=null; }
  }
  parts.forEach(p=>{
    p.vy+=0.06; p.x+=p.vx; p.y+=p.vy; p.life-=0.012;
    cx.globalAlpha=Math.max(p.life,0); cx.fillStyle=p.col;
    cx.beginPath(); cx.arc(p.x,p.y,p.r,0,7); cx.fill();
  });
  cx.globalAlpha=1;
  parts=parts.filter(p=>p.life>0);
  if(rocket||parts.length){ requestAnimationFrame(loop); }
  else { running=false; cx.clearRect(0,0,cv.width,cv.height); }
}

/* ====================================================
   4) SEQUENCE: start -> firework -> rainbow -> jungle -> welcome
==================================================== */
function begin(){
  makeAudio(); if(AC.state==='suspended')AC.resume();
  const ss=document.getElementById('startScreen');
  ss.style.opacity='0';
  setTimeout(()=>ss.style.display='none',700);

  whistle();
  launch();
  setTimeout(boom,900);                              // bang at the top
  setTimeout(()=>{                                    // rainbow appears
    document.getElementById('rainbow').classList.add('show');
  },1300);
  setTimeout(()=>{                                    // jungle + critters reveal
    document.getElementById('app').classList.add('reveal');
  },1700);
  setTimeout(()=>{ goto('welcome'); },3000);          // welcome message
}
document.getElementById('startBtn').addEventListener('click',begin);

/* ====================================================
   5) QUESTIONNAIRE LOGIC
==================================================== */
const data={attending:'',childName:'',method:'',contact:''};
function goto(id){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  const el=document.getElementById('p-'+id);
  if(el){ el.classList.add('active'); }
}
function answerAttend(yes){
  data.attending = yes ? 'Yes' : 'No';
  if(yes){ goto('q2'); setTimeout(()=>document.getElementById('childName').focus(),400); }
  else{ data.childName=''; data.method=''; data.contact=''; submitForm(true); }
}
function checkName(){
  const v=document.getElementById('childName').value.trim();
  data.childName=v;
  document.getElementById('nameNext').disabled = v.length<1;
}
function answerMethod(m){
  data.method=m;
  document.getElementById('m-email').classList.toggle('sel',m==='Email');
  document.getElementById('m-phone').classList.toggle('sel',m==='Phone');
  const lab=document.getElementById('q4label'), inp=document.getElementById('contactDetail');
  if(m==='Email'){ lab.textContent='Please enter your email address ✉️'; inp.type='email'; inp.placeholder='name@example.com'; inp.inputMode='email'; }
  else{ lab.textContent='Please enter your phone number 📞'; inp.type='tel'; inp.placeholder='Your phone number'; inp.inputMode='tel'; }
  inp.value=''; document.getElementById('sendBtn').disabled=true;
  goto('q4'); setTimeout(()=>inp.focus(),400);
}
function checkContact(){
  const v=document.getElementById('contactDetail').value.trim();
  data.contact=v;
  document.getElementById('sendBtn').disabled = v.length<3;
}

/* ====================================================
   6) SAVING THE ANSWERS
   >>> PUT YOUR FORMSPREE LINK BELOW <<<
==================================================== */
const FORM_ENDPOINT = "https://formspree.io/f/YOUR_FORM_ID";

function submitForm(notAttending){
  const payload={
    Attending:data.attending,
    Child_Name:data.childName,
    Contact_Method:data.method,
    Contact_Details:data.contact,
    Event:"Abdul Rafay 9th Birthday - June 28"
  };
  const isReady = FORM_ENDPOINT.indexOf('YOUR_FORM_ID')===-1;
  if(isReady){
    fetch(FORM_ENDPOINT,{method:'POST',headers:{'Accept':'application/json','Content-Type':'application/json'},
      body:JSON.stringify(payload)}).catch(()=>{});
  }
  if(notAttending){ goto('bye'); }
  else{
    document.getElementById('thanksMsg').textContent =
      (data.childName? data.childName.split(' ')[0]+' is on the list! ':'') + "We can't wait to see you at the party!";
    goto('thanks'); confettiBurst();
  }
}

/* ====================================================
   7) CONFETTI for the thank-you screen
==================================================== */
const cc=document.getElementById('confetti'), ccx=cc.getContext('2d');
function cs(){cc.width=innerWidth;cc.height=innerHeight;} cs(); addEventListener('resize',cs);
let conf=[];
function confettiBurst(){
  for(let i=0;i<120;i++){
    conf.push({x:innerWidth/2,y:innerHeight*0.35,
      vx:(Math.random()-0.5)*12,vy:Math.random()*-12-3,
      g:0.3,r:Math.random()*7+4,col:COLORS[(Math.random()*COLORS.length)|0],
      rot:Math.random()*6,vr:(Math.random()-0.5)*0.3,life:1});
  }
  confLoop();
}
function confLoop(){
  ccx.clearRect(0,0,cc.width,cc.height);
  conf.forEach(p=>{p.vy+=p.g;p.x+=p.vx;p.y+=p.vy;p.rot+=p.vr;p.life-=0.006;
    ccx.save();ccx.translate(p.x,p.y);ccx.rotate(p.rot);ccx.globalAlpha=Math.max(p.life,0);
    ccx.fillStyle=p.col;ccx.fillRect(-p.r/2,-p.r/2,p.r,p.r*0.6);ccx.restore();});
  conf=conf.filter(p=>p.life>0 && p.y<cc.height+40);
  if(conf.length)requestAnimationFrame(confLoop);
  else ccx.clearRect(0,0,cc.width,cc.height);
}
</script>
